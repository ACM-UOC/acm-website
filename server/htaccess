Options +FollowSymLinks
RewriteEngine On

# Serve real files directly (static assets via symlink)
RewriteCond %{REQUEST_FILENAME} -f
RewriteRule ^ - [L]

# Proxy everything else directly to Node.js (no PHP)
RewriteRule ^(.*)$ http://190.92.158.4:3000/$1 [P,L]

<IfModule LiteSpeed>
CacheLookup off
</IfModule>

<IfModule mod_headers.c>
Header always set Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"
</IfModule>

# Long-lived cache for hashed Next.js static assets (filenames change on deploy)
<FilesMatch "\.(js|css|woff2|woff|ttf)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
</FilesMatch>

# Shorter cache for images (not content-hashed)
<FilesMatch "\.(png|jpg|jpeg|svg|ico|webp)$">
    Header set Cache-Control "public, max-age=604800"
</FilesMatch>
